<form method="post" action="{{ path('karta_produktu_delete', {'id': karta_produktu.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_method" value="DELETE">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ karta_produktu.id) }}">
    <button class="btn">Delete</button>
</form>
